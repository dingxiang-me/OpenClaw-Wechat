# WeCom / 企业微信
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_CORP_SECRET=

# Callback verification
WECOM_CALLBACK_TOKEN=
WECOM_CALLBACK_AES_KEY=

# Optional: base path for webhook (default: /wecom/callback)
WECOM_WEBHOOK_PATH=/wecom/callback
WECOM_BOT_ENABLED=false
WECOM_BOT_TOKEN=
WECOM_BOT_ENCODING_AES_KEY=
WECOM_BOT_WEBHOOK_PATH=/wecom/bot/callback
WECOM_BOT_PLACEHOLDER_TEXT=消息已收到，正在处理中，请稍等片刻。
WECOM_BOT_STREAM_EXPIRE_MS=600000
WECOM_BOT_REPLY_TIMEOUT_MS=90000
WECOM_BOT_LATE_REPLY_WATCH_MS=180000
WECOM_BOT_LATE_REPLY_POLL_MS=2000

# Optional: outbound proxy for WeCom API (gettoken/message/send/media/get...)
WECOM_PROXY=
# Optional: account-scoped sender allowFrom override
# WECOM_SALES_ALLOW_FROM=alice,bob
# WECOM_SALES_ALLOW_FROM_REJECT_MESSAGE=销售账号未授权，请联系管理员。

# Optional: command and group policy
WECOM_ALLOW_FROM=
WECOM_ALLOW_FROM_REJECT_MESSAGE=当前账号未授权，请联系管理员。
WECOM_ADMIN_USERS=
WECOM_COMMANDS_ENABLED=false
WECOM_COMMANDS_ALLOWLIST=/help,/status,/clear,/reset,/new,/compact
WECOM_COMMANDS_REJECT_MESSAGE=该指令未开放，请联系管理员。
WECOM_GROUP_CHAT_ENABLED=true
WECOM_GROUP_CHAT_REQUIRE_MENTION=false
WECOM_GROUP_CHAT_TRIGGER_MODE=direct
WECOM_GROUP_CHAT_MENTION_PATTERNS=@
WECOM_GROUP_CHAT_TRIGGER_KEYWORDS=
WECOM_DEBOUNCE_ENABLED=false
WECOM_DEBOUNCE_WINDOW_MS=1200
WECOM_DEBOUNCE_MAX_BATCH=6
WECOM_STREAMING_ENABLED=false
WECOM_STREAMING_MIN_CHARS=120
WECOM_STREAMING_MIN_INTERVAL_MS=1200
WECOM_LATE_REPLY_WATCH_MS=180000
WECOM_LATE_REPLY_POLL_MS=2000
WECOM_DYNAMIC_AGENT_ENABLED=false
WECOM_DYNAMIC_AGENT_MODE=deterministic
WECOM_DYNAMIC_AGENT_ID_STRATEGY=readable-hash
WECOM_DYNAMIC_AGENT_PREFIX=wecom
WECOM_DYNAMIC_AGENT_AUTO_PROVISION=true
WECOM_DYNAMIC_AGENT_ALLOW_UNKNOWN_AGENT_ID=true
WECOM_DYNAMIC_AGENT_DEFAULT_AGENT_ID=
WECOM_DYNAMIC_AGENT_ADMIN_AGENT_ID=
WECOM_DYNAMIC_AGENT_ADMIN_USERS=
WECOM_DYNAMIC_AGENT_USER_MAP=
WECOM_DYNAMIC_AGENT_GROUP_MAP=
WECOM_DYNAMIC_AGENT_MENTION_MAP=

# Optional: local voice transcription fallback (used when WeCom Recognition is empty)
WECOM_VOICE_TRANSCRIBE_ENABLED=true
WECOM_VOICE_TRANSCRIBE_PROVIDER=local-whisper-cli
WECOM_VOICE_TRANSCRIBE_COMMAND=whisper-cli
WECOM_VOICE_TRANSCRIBE_MODEL_PATH=/usr/local/opt/whisper-cpp/share/whisper-cpp/for-tests-ggml-tiny.bin
WECOM_VOICE_TRANSCRIBE_MODEL=base
WECOM_VOICE_TRANSCRIBE_TIMEOUT_MS=120000
WECOM_VOICE_TRANSCRIBE_MAX_BYTES=10485760
WECOM_VOICE_TRANSCRIBE_FFMPEG_ENABLED=true
WECOM_VOICE_TRANSCRIBE_TRANSCODE_TO_WAV=true
